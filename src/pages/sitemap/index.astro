---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { categoryPages } from '../../data/categories';
import { getAllProductGuides } from '../../data/productGuides';

const title = 'Sitemap - interieurdesignerweb.nl';
const description =
  'Sitemap van Interieurdesignerweb.nl: alle pagina’s, productgidsen en blogartikelen.';

const staticPages = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Over ons', href: '/over-ons/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Partners', href: '/partners/' },
  { label: 'Sitemap', href: '/sitemap/' },
];

const pages = [
  ...staticPages,
  ...categoryPages.map((c) => ({ label: c.title, href: `/${c.slug}/` })),
].sort((a, b) => a.label.localeCompare(b.label, 'nl'));

const productGuides = getAllProductGuides()
  .map((g) => ({
    label: g.title.replace(/^De top 10 beste\s+/i, 'Top 10 ').replace(/\s+voor je interieur$/i, ''),
    href: `/${g.slug}/`,
    heading: g.heading,
  }))
  .sort((a, b) => a.label.localeCompare(b.label, 'nl'));

const blogPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'nl'))
  .map((post) => ({
    label: post.data.title,
    href: `/${post.data.slug || post.id}/`,
  }));

const sections = [
  { id: 'paginas', label: 'Pagina’s', count: pages.length },
  { id: 'productgidsen', label: 'Productgidsen', count: productGuides.length },
  { id: 'artikelen', label: 'Blogartikelen', count: blogPosts.length },
];
---
<SiteLayout title={title} description={description} canonicalPath="/sitemap/">
  <div class="home-wrap page-section">
    <header class="page-hero reveal">
      <p class="page-hero__label">Sitemap</p>
      <h1>Alle pagina’s</h1>
      <p>
        Overzicht van {pages.length} pagina’s, {productGuides.length} productgidsen en{' '}
        {blogPosts.length} artikelen — elke link werkt op deze site.
      </p>
    </header>

    <nav class="sitemap-jump reveal" aria-label="Spring naar sectie">
      {sections.map((section) => (
        <a href={`#${section.id}`}>
          <strong>{section.count}</strong>
          <span>{section.label}</span>
        </a>
      ))}
    </nav>

    <section class="sitemap-block reveal" id="paginas">
      <div class="sitemap-block__head">
        <p class="page-hero__label">Navigatie</p>
        <h2>Pagina’s</h2>
      </div>
      <ul class="sitemap-grid">
        {pages.map((item) => (
          <li>
            <a href={item.href}>
              <span>{item.label}</span>
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="sitemap-block reveal" id="productgidsen">
      <div class="sitemap-block__head">
        <p class="page-hero__label">Top 10 gidsen</p>
        <h2>Productgidsen</h2>
        <p>Alle productvergelijkingen, alfabetisch gesorteerd.</p>
      </div>
      <ul class="sitemap-grid sitemap-grid--dense">
        {productGuides.map((item) => (
          <li>
            <a href={item.href}>
              <span>{item.label}</span>
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="sitemap-block reveal" id="artikelen">
      <div class="sitemap-block__head">
        <p class="page-hero__label">Blog</p>
        <h2>Blogartikelen</h2>
        <p>Alle artikelen op Interieurdesignerweb.nl.</p>
      </div>
      <ul class="sitemap-grid sitemap-grid--dense">
        {blogPosts.map((item) => (
          <li>
            <a href={item.href}>
              <span>{item.label}</span>
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</SiteLayout>

<style>
  .sitemap-jump {
    display: grid;
    gap: 0.75rem;
    margin: 0 0 clamp(2.5rem, 6vw, 3.5rem);
  }

  @media (min-width: 700px) {
    .sitemap-jump {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .sitemap-jump a {
    display: grid;
    gap: 0.2rem;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--home-line);
    background:
      linear-gradient(145deg, rgba(36, 92, 69, 0.08), transparent 60%),
      rgba(251, 252, 251, 0.8);
    transition:
      transform 0.25s var(--home-ease),
      border-color 0.25s var(--home-ease);
  }

  .sitemap-jump a:hover {
    transform: translateY(-2px);
    border-color: rgba(36, 92, 69, 0.35);
  }

  .sitemap-jump strong {
    font-family: var(--font-display);
    font-size: 1.55rem;
    letter-spacing: -0.03em;
    color: var(--home-ink);
  }

  .sitemap-jump span {
    font-size: 0.9rem;
    color: var(--home-ink-soft);
    font-weight: 600;
  }

  .sitemap-block {
    margin-bottom: clamp(2.75rem, 7vw, 4rem);
  }

  .sitemap-block__head {
    margin-bottom: 1.25rem;
    max-width: 36rem;
  }

  .sitemap-block__head h2 {
    margin: 0 0 0.4rem;
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 3.2vw, 2.1rem);
    letter-spacing: -0.035em;
  }

  .sitemap-block__head p:last-child {
    margin: 0;
    color: var(--home-ink-soft);
  }

  .sitemap-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }

  @media (min-width: 700px) {
    .sitemap-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .sitemap-grid--dense {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .sitemap-grid a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.85rem;
    min-height: 3rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--home-line);
    background: rgba(251, 252, 251, 0.78);
    color: var(--home-ink);
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.35;
    transition:
      transform 0.25s var(--home-ease),
      border-color 0.25s var(--home-ease),
      color 0.2s var(--home-ease),
      background 0.25s var(--home-ease);
  }

  .sitemap-grid a:hover {
    transform: translateY(-2px);
    border-color: rgba(36, 92, 69, 0.35);
    color: var(--home-moss-deep);
    background: rgba(251, 252, 251, 0.98);
  }

  .sitemap-grid a span:last-child {
    color: var(--home-moss);
    flex: 0 0 auto;
  }
</style>
