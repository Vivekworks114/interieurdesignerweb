---
import SiteLayout from '../../layouts/SiteLayout.astro';
---
<SiteLayout
  title="Partners | Interieurdesignerweb.nl"
  description="Partners van Interieurdesignerweb.nl"
  canonicalPath="/partners/"
>
  <div class="home-wrap page-section">
    <header class="page-hero reveal">
      <p class="page-hero__label">Partners</p>
      <h1>Samen sterker</h1>
      <p>
        We werken samen met betrouwbare partners om jou de beste producten en diensten te bieden.
      </p>
    </header>
    <div class="theme-content reveal">
      <p>
        Interieurdesignerweb.nl werkt met geselecteerde partners op het gebied van interieur,
        woninginrichting en productvergelijkingen.
      </p>
      <p>
        Ben je geïnteresseerd in een samenwerking? Neem dan <a href="/contact/">contact</a> met ons
        op.
      </p>
    </div>
  </div>
</SiteLayout>
