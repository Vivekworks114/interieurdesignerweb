---
import { heroContent } from '../data/homepage';
---
<section class="hero section">
  <div class="hero__inner container">
    <div class="hero__image reveal">
      <img
        src={heroContent.heroImage}
        alt={heroContent.heroAlt}
        width="600"
        height="500"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero__content reveal">
      <h1>{heroContent.title}</h1>
      <p>{heroContent.description}</p>
      <p>{heroContent.description2}</p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .hero__image img {
    width: 100%;
    max-width: 540px;
    height: auto;
    object-fit: contain;
    border-radius: var(--card-radius-lg);
  }

  .hero__content {
    max-width: 32rem;
  }

  .hero__content h1 {
    margin-bottom: 1.25rem;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }

  .hero__content p {
    font-size: 1rem;
    line-height: 1.7;
  }

  @media (max-width: 1023px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__image {
      order: -1;
      max-width: 28rem;
      margin-inline: auto;
    }

    .hero__content {
      max-width: 100%;
    }
  }
</style>
