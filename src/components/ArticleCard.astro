---
interface Props {
  title: string;
  href: string;
  image: string;
}

const { title, href, image } = Astro.props;
---
<article class="article-card reveal">
  <a href={href} class="article-card__link">
    <div class="article-card__image">
      <img src={image} alt={title} width="400" height="267" loading="lazy" />
    </div>
    <h3 class="article-card__title">{title}</h3>
  </a>
</article>

<style>
  .article-card__link {
    display: block;
    height: 100%;
    transition: transform var(--transition);
  }

  .article-card__link:hover {
    transform: translateY(-4px);
  }

  .article-card__image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: var(--card-radius);
    background: var(--color-bg-soft);
    margin-bottom: 1rem;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition);
  }

  .article-card__link:hover .article-card__image {
    box-shadow: var(--shadow-hover);
  }

  .article-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .article-card__link:hover .article-card__image img {
    transform: scale(1.04);
  }

  .article-card__title {
    font-family: var(--font-card);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-heading);
    margin: 0;
    transition: color var(--transition);
  }

  .article-card__link:hover .article-card__title {
    color: var(--color-accent);
  }
</style>
