---
---
<section class="contact section">
  <div class="container">
    <div class="contact__inner reveal">
      <div class="contact__content">
        <h2>Neem contact met ons op</h2>
        <p>
          Heb je vragen over interieurproducten of wil je advies over het inrichten van je woning?
          Neem gerust contact met ons op. We helpen je graag verder.
        </p>
      </div>
      <form class="contact__form" action="#" method="post">
        <div class="contact__field">
          <label for="name">Naam</label>
          <input type="text" id="name" name="name" required autocomplete="name" />
        </div>
        <div class="contact__field">
          <label for="email">E-mailadres</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div class="contact__field">
          <label for="message">Bericht</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn--accent">Versturen</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    max-width: 56rem;
    margin-inline: auto;
  }

  .contact__content h2 {
    margin-bottom: 1rem;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact__field label {
    font-family: var(--font-nav);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-heading);
  }

  .contact__field input,
  .contact__field textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .contact__field input:focus,
  .contact__field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(105, 197, 211, 0.2);
  }

  @media (max-width: 767px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
