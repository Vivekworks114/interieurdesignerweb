---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="home-wrap footer__inner">
    <div>
      <p class="footer__brand">Interieurdesignerweb</p>
      <p class="footer__note">Tips, vergelijkingen en inspiratie voor een doordacht interieur.</p>
    </div>
    <nav class="footer__nav" aria-label="Footer">
      <a href="/blog/">Blog</a>
      <a href="/sitemap/">Sitemap</a>
      <a href="/partners/">Partners</a>
      <a href="/contact/">Contact</a>
    </nav>
  </div>
  <div class="home-wrap footer__legal">
    <span>© {year} Interieurdesignerweb.nl</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--home-line);
    padding-block: 3rem 2rem;
    background: #101612;
    color: rgba(251, 252, 251, 0.82);
  }

  .footer__inner {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .footer__brand {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--home-white);
  }

  .footer__note {
    margin: 0;
    max-width: 28rem;
  }

  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }

  .footer__nav a:hover {
    color: var(--home-white);
  }

  .footer__legal {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  @media (min-width: 800px) {
    .footer__inner {
      grid-template-columns: 1.4fr 1fr;
      align-items: end;
    }
  }
</style>
