---
import { categoryColumns } from '../data/homepage';
---
<section class="features section section--soft">
  <div class="container">
    <div class="section-title reveal">
      <h2>Categorieën</h2>
    </div>
    <div class="category-columns reveal">
      {categoryColumns.map((column) => (
        <ul>
          {column.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      ))}
    </div>
  </div>
</section>
